{
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prisma:*)",
      "Bash(npx tsc:*)",
      "Bash(node -e:*)",
      "Bash(git:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(npm publish:*)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-branch.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-generated.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-vitest.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/typecheck.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/lint-on-save.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/log-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify-slack.sh"
          }
        ]
      }
    ]
  }
}
